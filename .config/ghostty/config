# Ghostty terminal config
# Docs: https://ghostty.org/docs/config

# Typography
font-family = "SF Mono"
font-size = 14
font-thicken = false

# Window
window-padding-x = 10
window-padding-y = 10
background-opacity = 1.0
copy-on-select = true

# Cursor
cursor-style = bar

# Theme
theme = Ghostty Default Style Dark
