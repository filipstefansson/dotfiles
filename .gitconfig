[user]
	name = Filip Stefansson
	email = filip.stefansson@gmail.com
	# Commit signing via the 1Password SSH agent. To enable on a new machine:
	#   1. In 1Password, create a new SSH key (or open an existing one).
	#   2. 1Password → Settings → Developer → "Use the SSH agent" + "Sign Git
	#      commits" (this also offers to write the config below for you).
	#   3. Paste the key's PUBLIC part here, then set commit.gpgsign = true.
	#   4. Add the same public key to GitHub as a *Signing* key for the
	#      "Verified" badge (Settings → SSH and GPG keys → New, type: Signing).
	# signingkey = ssh-ed25519 AAAA...PASTE_FROM_1PASSWORD

[init]
	defaultBranch = main

[gpg]
	format = ssh

[gpg "ssh"]
	program = "/Applications/1Password.app/Contents/MacOS/op-ssh-sign"

[commit]
	# Flip to true once signingkey above is set and the 1Password agent is on.
	gpgsign = false

[tag]
	gpgsign = false

[core]
	excludesfile = ~/.gitignore_global
	pager = delta

[interactive]
	diffFilter = delta --color-only

[delta]
	navigate = true
	line-numbers = true

[pull]
	rebase = true

[push]
	autoSetupRemote = true

[fetch]
	prune = true

[rebase]
	updateRefs = true

[diff]
	algorithm = histogram
	colorMoved = default

[merge]
	conflictstyle = zdiff3

[branch]
	sort = -committerdate

[column]
	ui = auto

[rerere]
	enabled = true

[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true

[credential "https://github.com"]
	helper =
	helper = !/opt/homebrew/bin/gh auth git-credential

[credential "https://gist.github.com"]
	helper =
	helper = !/opt/homebrew/bin/gh auth git-credential
