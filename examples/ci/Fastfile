# Reference Fastfile — copy to fastlane/Fastfile in the iOS app repo.
# The "beta" lane builds a signed .ipa and ships it to TestFlight, with no
# interactive prompts, on this Mac's self-hosted runner.

default_platform(:ios)

platform :ios do
  desc "Build a signed .ipa and upload to TestFlight"
  lane :beta do
    # Creates a temporary, isolated keychain for this job and tears it down
    # afterwards — keeps signing off the login keychain. No-op locally.
    setup_ci

    # App Store Connect API key from env (set in the workflow). Used by both
    # match (fetching profiles) and pilot (uploading).
    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_API_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_API_ISSUER_ID"],
      key_content: ENV["APP_STORE_CONNECT_API_KEY_CONTENT"],
    )

    # Pull the distribution cert + provisioning profile into the CI keychain.
    match(type: "appstore", readonly: true, api_key: api_key)

    # Build + sign.
    gym(scheme: "App", export_method: "app-store")

    # Upload to TestFlight.
    pilot(api_key: api_key, skip_waiting_for_build_processing: true)
  end
end
